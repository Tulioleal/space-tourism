---
interface Props {
  number: string;
  text: string;
}

const { number, text } = Astro.props;
---

<h1 class="numbered-title ff-sans-cond uppercase letter-spacing-1">
  <span aria-hidden="true">{number}</span>{text}
</h1>

<style lang="scss">
  @use "../styles/variables" as *;
  @use "../styles/mixins" as *;

  .numbered-title {
    font-size: $fs-500;
    text-align: center;

    span {
      margin-right: 0.5em;
      font-weight: 700;
      color: hsl(0 0% 100% / 0.25);
    }

    @include tablet {
      text-align: left;
      margin-left: 2rem;
    }

    @include desktop {
      margin-left: 0;
    }
  }
</style>
