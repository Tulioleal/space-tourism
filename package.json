{
  "name": "space-tourism",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint ."
  },
  "dependencies": {
    "astro": "^5.17.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.2",
    "eslint-plugin-astro": "^1.6.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "prettier-plugin-astro": "^0.14.1",
    "sass": "^1.97.3",
    "simple-git-hooks": "^2.11.1",
    "typescript-eslint": "^8.56.1"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged",
    "commit-msg": "npx commitlint --edit $1",
    "pre-push": "branch=$(git rev-parse --abbrev-ref HEAD) && if echo \"$branch\" | grep -qE '^(main|master|develop)$'; then exit 0; elif echo \"$branch\" | grep -qE '^(feat|fix|chore|docs|style|refactor|test|build|ci|perf)/.+$'; then exit 0; else echo \"Branch name '$branch' does not follow type/description convention\" && exit 1; fi"
  },
  "lint-staged": {
    "*.{astro,js,ts}": "eslint --fix",
    "*.{astro,scss,css,js,ts,json,md}": "prettier --write"
  }
}
